# Server Configuration
PORT=3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/cronie

# AI Configuration (OpenRouter)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: AI Model Selection (default: openai/gpt-4o-mini)
# Other options: anthropic/claude-3.5-sonnet, google/gemini-pro, etc.
AI_MODEL=openai/gpt-4o-mini

# Optional: AI Request Timeout in milliseconds (default: 10000)
AI_TIMEOUT_MS=10000

# Optional: Maximum number of retries for AI requests (default: 2)
AI_MAX_RETRIES=2

# Optional: Base delay for retry backoff in milliseconds (default: 1000)
AI_BASE_DELAY_MS=1000
